# ============================================================
#  Variables de entorno — copiá este archivo a .env.local
#  y completá los valores. .env.local NO se sube a git.
# ============================================================

# --- Panel de administración (/admin) ---
# Contraseña para entrar al panel de consultas.
ADMIN_PASSWORD=cambiá-esta-contraseña

# Secreto para firmar la cookie de sesión. Generá uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=pega-aca-un-secreto-largo-y-aleatorio

# --- Base de datos ---
# En desarrollo NO hace falta definir nada: usa un archivo local
# (file:./data/leads.db) automáticamente.
#
# En producción (Turso), creá una base gratis en https://turso.tech
# y pegá acá las credenciales:
# TURSO_DATABASE_URL=libsql://tu-base.turso.io
# TURSO_AUTH_TOKEN=tu-token-de-turso
